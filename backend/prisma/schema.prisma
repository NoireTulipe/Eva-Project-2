generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ─── RÉFÉRENCES ───────────────────────────────────────────────────────────────

model TypeContact {
  id       Int       @id @default(autoincrement())
  nom      String    @unique
  contacts Contact[]
}

model Categorie {
  id       Int       @id @default(autoincrement())
  nom      String    @unique
  produits Produit[]
}

model TypePDV {
  id            Int            @id @default(autoincrement())
  nom           String         @unique
  pointsDeVente PointDeVente[]
}

model TypeHorsStock {
  id         Int                  @id @default(autoincrement())
  nom        String               @unique
  mouvements MouvementHorsStock[]
}

model TypePerte {
  id     Int     @id @default(autoincrement())
  nom    String  @unique
  pertes Perte[]
}

model TypeFrais {
  id    Int     @id @default(autoincrement())
  nom   String  @unique
  frais Frais[]
}

model MethodePaiement {
  id     Int     @id @default(autoincrement())
  nom    String  @unique
  ventes Vente[]
}

// ─── CONTACTS ─────────────────────────────────────────────────────────────────

model Contact {
  id            Int            @id @default(autoincrement())
  nom           String
  prenom        String?
  email         String?
  telephone     String?
  description   String?
  typeId        Int
  type          TypeContact    @relation(fields: [typeId], references: [id])
  pointsDeVente PointDeVente[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

// ─── AUTEURS ──────────────────────────────────────────────────────────────────

model Auteur {
  id        Int             @id @default(autoincrement())
  nom       String
  prenom    String?
  email     String?
  produits  AuteurProduit[]
  createdAt DateTime        @default(now())
  updatedAt DateTime        @updatedAt
}

// ─── PRODUITS ─────────────────────────────────────────────────────────────────

model Produit {
  id                  Int                  @id @default(autoincrement())
  nom                 String
  description         String?
  categorieId         Int
  categorie           Categorie            @relation(fields: [categorieId], references: [id])
  prixVenteTTC        Float
  tva                 Float                @default(0)
  cout                Float
  droitAuteur         Boolean              @default(false)
  droitAuteurPourcent Float                @default(0)
  stock               Int                  @default(0)
  stockAlerte         Int                  @default(5)
  actif               Boolean              @default(true)
  auteurs             AuteurProduit[]
  mouvementsHorsStock MouvementHorsStock[]
  pertes              Perte[]
  depots              Depot[]
  lignesVente         LigneVente[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

// Relation many-to-many Auteur <-> Produit
model AuteurProduit {
  auteurId  Int
  produitId Int
  auteur    Auteur  @relation(fields: [auteurId], references: [id])
  produit   Produit @relation(fields: [produitId], references: [id])

  @@id([auteurId, produitId])
}

// ─── HORS STOCK ───────────────────────────────────────────────────────────────

model MouvementHorsStock {
  id              Int           @id @default(autoincrement())
  produitId       Int
  produit         Produit       @relation(fields: [produitId], references: [id])
  typeHorsStockId Int
  typeHorsStock   TypeHorsStock @relation(fields: [typeHorsStockId], references: [id])
  quantite        Int
  description     String?
  createdAt       DateTime      @default(now())
}

// ─── PERTES ───────────────────────────────────────────────────────────────────

model Perte {
  id          Int       @id @default(autoincrement())
  typePerteid Int
  typePerte   TypePerte @relation(fields: [typePerteid], references: [id])
  produitId   Int?
  produit     Produit?  @relation(fields: [produitId], references: [id])
  quantite    Int?
  valeur      Float
  description String?
  createdAt   DateTime  @default(now())
}

// ─── FRAIS ────────────────────────────────────────────────────────────────────

model Frais {
  id          Int       @id @default(autoincrement())
  typeFraisId Int
  typeFrais   TypeFrais @relation(fields: [typeFraisId], references: [id])
  libelle     String
  montant     Float
  sessionId   Int?
  session     Session?  @relation(fields: [sessionId], references: [id])
  createdAt   DateTime  @default(now())
}

// ─── POINTS DE VENTE ──────────────────────────────────────────────────────────

model PointDeVente {
  id                 Int       @id @default(autoincrement())
  nom                String
  adresse            String?
  ville              String?
  latitude           Float?
  longitude          Float?
  typePDVId          Int
  typePDV            TypePDV   @relation(fields: [typePDVId], references: [id])
  contactId          Int?
  contact            Contact?  @relation(fields: [contactId], references: [id])
  commissionFixe     Float     @default(0)
  commissionPourcent Float     @default(0)
  typeEncaissement   String    @default("nous")
  actif              Boolean   @default(true)
  sessions           Session[]
  depots             Depot[]
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

// ─── DÉPÔTS ───────────────────────────────────────────────────────────────────

model Depot {
  id             Int          @id @default(autoincrement())
  produitId      Int
  produit        Produit      @relation(fields: [produitId], references: [id])
  pointDeVenteId Int
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  quantite       Int
  quantiteVendue Int          @default(0)
  dateDepot      DateTime     @default(now())
  dateRetour     DateTime?
  actif          Boolean      @default(true)
  notes          String?
}

// ─── SESSIONS ─────────────────────────────────────────────────────────────────

model Session {
  id             Int          @id @default(autoincrement())
  pointDeVenteId Int
  pointDeVente   PointDeVente @relation(fields: [pointDeVenteId], references: [id])
  statut         String       @default("ouverte")
  remiseGlobale  Float        @default(0)
  debut          DateTime
  fin            DateTime?
  frais          Frais[]
  ventes         Vente[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

// ─── VENTES ───────────────────────────────────────────────────────────────────

model Vente {
  id                Int              @id @default(autoincrement())
  sessionId         Int?
  session           Session?         @relation(fields: [sessionId], references: [id])
  methodePaiementId Int?
  methodePaiement   MethodePaiement? @relation(fields: [methodePaiementId], references: [id])
  type              String           @default("session")
  annulee           Boolean          @default(false)
  lignes            LigneVente[]
  createdAt         DateTime         @default(now())
}

// type : "session" | "site" | "siege" | "depot"

model LigneVente {
  id           Int      @id @default(autoincrement())
  venteId      Int
  vente        Vente    @relation(fields: [venteId], references: [id])
  produitId    Int
  produit      Produit  @relation(fields: [produitId], references: [id])
  quantite     Int
  prixUnitaire Float
  remise       Float    @default(0)
  createdAt    DateTime @default(now())
}

// ─── UTILISATEURS ─────────────────────────────────────────────────────────────

model User {
  id        Int      @id @default(autoincrement())
  nom       String
  prenom    String?
  email     String   @unique
  password  String
  role      String   @default("user")
  actif     Boolean  @default(true)
  discordId String?  @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── MAIL ─────────────────────────────────────────────────────────────────────

model BoiteMail {
  id                    Int        @id @default(autoincrement())
  nom                   String
  email                 String     @unique
  provider              String     // "gmail" | "outlook" | "imap"
  actif                 Boolean    @default(true)

  // IMAP
  imapHost              String     @default("")
  imapPort              Int        @default(993)
  imapLogin             String     @default("")
  imapPassword          String     @default("")

  // SMTP
  smtpHost              String     @default("")
  smtpPort              Int        @default(587)
  smtpLogin             String     @default("")
  smtpPassword          String     @default("")

  // Scan
  scanNonLuSeulement    Boolean    @default(true)
  scanNombre            Int        @default(20)

  // Instruction EVA spécifique à cette boîte
  instructionSpecifique String     @default("")

  // Canal Discord pour le rapport quotidien (ID du salon)
  salonDiscordRapport   String     @default("")

  emailLogs    EmailLog[]
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt
}

model EmailLog {
  id               Int        @id @default(autoincrement())
  boiteMailId      Int
  boiteMail        BoiteMail  @relation(fields: [boiteMailId], references: [id])
  uid              Int?       // UID IMAP du mail
  sujet            String?
  expediteur       String?
  corps            String?    // résumé du corps (500 cars max)
  dossier          String?    // dossier IMAP source
  categorie        String?    // catégorie attribuée par EVA
  action           String?    // action prise par EVA
  raison           String?    // explication d'EVA
  actionAppliquee  Boolean    @default(false)
  brouillon        String?    // corps rédigé par EVA si action = "repondre"
  brouillonEnvoye  Boolean    @default(false)
  createdAt        DateTime   @default(now())
}

// ─── NOTES ET RAPPELS ─────────────────────────────────────────────────────────

model Note {
  id        Int      @id @default(autoincrement())
  titre     String?
  contenu   String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Rappel {
  id          Int       @id @default(autoincrement())
  contenu     String
  echeance    DateTime
  envoye      Boolean   @default(false)
  createdAt   DateTime  @default(now())
}

// ─── CONVERSATIONS ────────────────────────────────────────────────────────────

model Conversation {
  id        Int       @id @default(autoincrement())
  userId    Int
  titre     String    @default("Nouvelle conversation")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  messages  Message[]
}

model Message {
  id             Int          @id @default(autoincrement())
  conversationId Int
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           String       // "user" | "assistant"
  content        String
  createdAt      DateTime     @default(now())
}

// ─── MÉMOIRE ──────────────────────────────────────────────────────────────────

model MemBuffer {
  id        Int      @id @default(autoincrement())
  source    String
  contenu   String
  traite    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model MemContact {
  id        Int      @id @default(autoincrement())
  userId    Int
  nom       String
  contenu   String
  embedding String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MemPreference {
  id        Int      @id @default(autoincrement())
  userId    Int
  cle       String
  contenu   String
  embedding String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, cle])
}

model MemSouvenir {
  id        Int      @id @default(autoincrement())
  userId    Int
  contenu   String
  embedding String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── CONFIG SYSTÈME ───────────────────────────────────────────────────────────

model ConfigParam {
  id        Int      @id @default(autoincrement())
  cle       String   @unique
  valeur    String
  description String?
  updatedAt DateTime @updatedAt
}

model Prompt {
  id          Int      @id @default(autoincrement())
  module      String
  role        String
  contenu     String
  actif       Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([module, role])
}

model CronConfig {
  id          Int      @id @default(autoincrement())
  nom         String   @unique
  expression  String
  actif       Boolean  @default(true)
  description String?
  updatedAt   DateTime @updatedAt
}

// ─── DISCORD ──────────────────────────────────────────────────────────────────

model CanalDiscord {
  id         Int      @id @default(autoincrement())
  channelId  String   @unique
  nom        String
  mode       String   @default("conversation") // "outils" | "conversation"
  categories String   @default("[]")           // JSON : ["ventes", "web", "memoire"]
  actif      Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

